              }
            ],
            "url": {
              "raw": "{{app_url}}/api/superadmin/admins/2/toggle",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "admins", "2", "toggle"]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "app_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ]
