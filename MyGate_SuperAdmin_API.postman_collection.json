              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Horizon Society\",\n  \"city\": \"Mumbai\",\n  \"contactEmail\": \"admin@newhorizon.com\",\n  \"plan\": \"professional\",\n  \"towers\": 3,\n  \"totalFlats\": 150\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{app_url}}/api/superadmin/societies",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "societies"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin Management",
      "item": [
        {
          "name": "List All Admins",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
