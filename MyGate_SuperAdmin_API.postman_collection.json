{
  "info": {
    "name": "MyGate Super Admin API",
    "description": "API endpoints for the Super Admin Dashboard and Management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Stats",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{app_url}}/api/superadmin/stats",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "stats"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Society Registrations (Leads)",
      "item": [
        {
          "name": "List All Registrations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{app_url}}/api/superadmin/registrations",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "registrations"]
            }
          },
          "response": []
        },
        {
          "name": "Filter Registrations by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{app_url}}/api/superadmin/registrations?status=new",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "registrations"],
              "query": [
                {
                  "key": "status",
                  "value": "new"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Registration Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"under_review\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{app_url}}/api/superadmin/registrations/1",
              "host": ["{{app_url}}"],
              "path": ["api", "superadmin", "registrations", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
