{
    "name": "migate/backend-full",
    "description": "Complete backend implementation for MiGate property management system",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "MiGate Development Team",
            "email": "development@migate.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "MiGate\\": "app/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "phpcbf app/ tests/",
        "cs-check": "phpcs app/ tests/"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}